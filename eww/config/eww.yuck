(include "./init-vars.yuck")

(defwindow bar-primary
    :monitor 0
    :geometry (geometry :x "0%"
                        :y "10px"
                        :width "99%"
                        :height "30px"
                        :anchor "top center")
    :stacking "fg"
    :focusable "none"
    :exclusive true
  "example co ${user-name}")
